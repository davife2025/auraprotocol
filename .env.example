# ─────────────────────────────────────────────
# Aura Protocol — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000

# ── Database (PostgreSQL) ────────────────────
DATABASE_URL=postgresql://aura:aura@localhost:5432/aura_dev
REDIS_URL=redis://localhost:6379

# ── Monad Blockchain ─────────────────────────
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
MONAD_WS_URL=wss://testnet-rpc.monad.xyz

# Contract addresses (set after deployment)
AURA_IDENTITY_CONTRACT=
AURA_PERMISSIONS_CONTRACT=
AURA_REGISTRY_CONTRACT=
AURA_REPUTATION_CONTRACT=
AURA_MEETING_FACTORY_CONTRACT=
AURA_TOKEN_CONTRACT=

# Deployer wallet (NEVER commit real keys)
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# ── AI (Anthropic) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Auth ─────────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=generate-with-openssl-rand-base64-32

# ── Payments (Stripe) ────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# ── Vector DB (agent memory) ─────────────────
PINECONE_API_KEY=your-pinecone-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX=aura-agent-memory

# ── Storage ──────────────────────────────────
S3_BUCKET=aura-protocol-uploads
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Next.js public vars ──────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_MONAD_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_CHAIN_ID=10143

# Session 2 — Additional contracts
AURA_MEETING_FACTORY_CONTRACT=

# Session 8 — Billing (Stripe)
STRIPE_PRO_PRICE_ID=price_test_xxx
STRIPE_BUSINESS_PRICE_ID=price_test_xxx

# Session 8 — Analytics
NEXT_PUBLIC_POSTHOG_KEY=
