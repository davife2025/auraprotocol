# ─────────────────────────────────────────────────────────────────────────────
# Aura Protocol — Environment Variables  (Stellar blockchain build)
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3001

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aura:aura@localhost:5432/aura_dev
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Stellar / Soroban ─────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Admin deployer secret (NEVER commit real keys)
STELLAR_SECRET_KEY=XXXXXXXXXXXXXXXXX

# Soroban contract IDs — filled after running scripts/deploy-stellar.ts
STELLAR_IDENTITY_CONTRACT=
STELLAR_REPUTATION_CONTRACT=
STELLAR_PERMISSIONS_CONTRACT=
STELLAR_MEETING_FACTORY_CONTRACT=
STELLAR_TOKEN_CONTRACT=

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=replace-me

# ── Billing (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_BUSINESS_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ── Vector memory (Pinecone) ──────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX=aura-agent-memory

# ── Next.js public ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
