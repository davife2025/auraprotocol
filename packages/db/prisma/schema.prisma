generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  email         String?  @unique
  displayName   String?
  avatarUrl     String?
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agents        Agent[]
  rooms         RoomMember[]
  subscriptions Subscription[]

  @@map("users")
}

// ─── Agents ──────────────────────────────────────────────────────────────────

model Agent {
  id                    String      @id @default(cuid())
  userId                String
  name                  String
  status                AgentStatus @default(IDLE)

  // Onchain identity
  walletAddress         String?     @unique
  identityTokenId       String?     @unique
  onchainTxHash         String?

  // Profile
  communicationStyle    String      @default("professional")
  riskTolerance         String      @default("moderate")
  timezone              String      @default("UTC")
  language              String      @default("en")
  customInstructions    String?

  // Permissions (stored as JSON, enforced onchain)
  permissions           Json

  // Reputation
  reputationScore       Int         @default(0)
  totalInteractions     Int         @default(0)
  commitmentRate        Float       @default(1.0)

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  memories              AgentMemory[]
  meetingParticipants   MeetingParticipant[]
  roomPresences         RoomPresence[]
  connectionsInitiated  AgentConnection[] @relation("ConnectionInitiator")
  connectionsReceived   AgentConnection[] @relation("ConnectionReceiver")

  @@map("agents")
}

enum AgentStatus {
  IDLE
  ACTIVE
  IN_MEETING
  IN_ROOM
  PAUSED
  ERROR
}

// ─── Agent Memory ─────────────────────────────────────────────────────────────

model AgentMemory {
  id          String   @id @default(cuid())
  agentId     String
  type        String   // preference | interaction | commitment | relationship | instruction
  content     String
  importance  Float    @default(0.5)
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, type])
  @@map("agent_memories")
}

// ─── Meetings ────────────────────────────────────────────────────────────────

model Meeting {
  id                  String        @id @default(cuid())
  title               String
  agenda              String?
  mode                MeetingMode   @default(HYBRID)
  status              MeetingStatus @default(SCHEDULED)
  scheduledAt         DateTime
  startedAt           DateTime?
  endedAt             DateTime?

  // Onchain settlement
  contractAddress     String?
  settlementTxHash    String?
  outcomeHash         String?

  // AI generated summary
  summary             String?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  participants        MeetingParticipant[]
  commitments         MeetingCommitment[]
  transcriptEntries   TranscriptEntry[]

  @@map("meetings")
}

enum MeetingMode {
  FULL_AGENT
  HYBRID
  OBSERVER
}

enum MeetingStatus {
  SCHEDULED
  ACTIVE
  ENDED
  SETTLED
  CANCELLED
}

model MeetingParticipant {
  id          String   @id @default(cuid())
  meetingId   String
  agentId     String
  role        String   @default("participant") // participant | observer
  joinedAt    DateTime?
  leftAt      DateTime?

  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  agent       Agent    @relation(fields: [agentId], references: [id])

  @@unique([meetingId, agentId])
  @@map("meeting_participants")
}

model TranscriptEntry {
  id          String   @id @default(cuid())
  meetingId   String
  agentId     String
  message     String
  turnNumber  Int
  timestamp   DateTime @default(now())

  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId, turnNumber])
  @@map("transcript_entries")
}

model MeetingCommitment {
  id               String   @id @default(cuid())
  meetingId        String
  agentId          String
  commitment       String
  commitmentType   String
  isApprovedByHuman Boolean @default(false)
  onchainTxHash    String?
  createdAt        DateTime @default(now())

  meeting          Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("meeting_commitments")
}

// ─── Rooms ───────────────────────────────────────────────────────────────────

model Room {
  id            String   @id @default(cuid())
  name          String
  niche         String
  description   String?
  isPremium     Boolean  @default(false)
  stakeRequired String?  // MON in wei
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members       RoomMember[]
  presences     RoomPresence[]

  @@index([niche])
  @@map("rooms")
}

model RoomMember {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  joinedAt  DateTime @default(now())

  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@map("room_members")
}

model RoomPresence {
  id        String    @id @default(cuid())
  roomId    String
  agentId   String
  enteredAt DateTime  @default(now())
  leftAt    DateTime?

  room      Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  agent     Agent     @relation(fields: [agentId], references: [id])

  @@map("room_presences")
}

// ─── Agent Connections ───────────────────────────────────────────────────────

model AgentConnection {
  id              String            @id @default(cuid())
  initiatorId     String
  receiverId      String
  roomId          String?
  status          ConnectionStatus  @default(PENDING)
  alignmentScore  Float?
  onchainTxHash   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  initiator       Agent             @relation("ConnectionInitiator", fields: [initiatorId], references: [id])
  receiver        Agent             @relation("ConnectionReceiver", fields: [receiverId], references: [id])
  chatMessages    ConnectionChat[]

  @@unique([initiatorId, receiverId])
  @@map("agent_connections")
}

enum ConnectionStatus {
  PENDING
  ACTIVE
  REJECTED
  ENDED
}

model ConnectionChat {
  id           String          @id @default(cuid())
  connectionId String
  fromAgentId  String
  message      String
  turnNumber   Int
  timestamp    DateTime        @default(now())

  connection   AgentConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, turnNumber])
  @@map("connection_chats")
}

// ─── Subscriptions ───────────────────────────────────────────────────────────

model Subscription {
  id                  String             @id @default(cuid())
  userId              String
  plan                SubscriptionPlan   @default(FREE)
  status              SubscriptionStatus @default(ACTIVE)
  stripeCustomerId    String?
  stripeSubscriptionId String?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}
