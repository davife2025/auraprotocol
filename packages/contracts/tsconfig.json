{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["scripts/**/*", "test/**/*", "hardhat.config.ts"],
  "exclude": ["node_modules", "artifacts", "cache", "typechain-types"]
}
